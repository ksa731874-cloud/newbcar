# Railway MySQL Database Configuration
# These variables are automatically provided by Railway when MySQL service is connected

# MySQL Connection Details
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_password_here
MYSQL_DATABASE=railway
MYSQL_ROOT_PASSWORD=your_root_password_here

# Railway-specific variables (auto-populated)
RAILWAY_PRIVATE_DOMAIN=mysql.railway.internal
RAILWAY_TCP_PROXY_DOMAIN=your-tcp-proxy-domain
RAILWAY_TCP_PROXY_PORT=3306

# Database URLs (for reference)
# Internal connection (within Railway)
MYSQL_URL=mysql://root:password@mysql.railway.internal:3306/railway

# Public connection (from outside Railway)
MYSQL_PUBLIC_URL=mysql://root:password@your-tcp-proxy-domain:3306/railway

# Pusher Configuration (Real-time)
PUSHER_APP_ID=1918568
PUSHER_KEY=4a9de0023f3255d461d9
PUSHER_SECRET=3803f60c4dc433d66655
PUSHER_CLUSTER=ap2

# Mail Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=BCare

