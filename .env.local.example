# Local Development Environment Variables
# Copy this file to .env and fill in your local database credentials
# DO NOT commit .env to Git - it's in .gitignore

# Railway MySQL Database Configuration
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_local_password
MYSQL_DATABASE=railway
MYSQL_ROOT_PASSWORD=your_local_root_password

# Railway-specific variables (for production)
# These are automatically set by Railway in production
RAILWAY_PRIVATE_DOMAIN=mysql.railway.internal
RAILWAY_TCP_PROXY_DOMAIN=your-tcp-proxy-domain
RAILWAY_TCP_PROXY_PORT=3306

# Application Settings
DEBUG_MODE=true
APP_ENV=development

# Pusher Configuration (Real-time)
PUSHER_APP_ID=1918568
PUSHER_KEY=4a9de0023f3255d461d9
PUSHER_SECRET=3803f60c4dc433d66655
PUSHER_CLUSTER=ap2

# Mail Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=BCare

